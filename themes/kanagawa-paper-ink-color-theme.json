    },
    "macro": "#c4746e",
    "method": "#859fac",
    "namespace": "#C8C093",
    "newOperator": "#c5c9c5",
    "numberLiteral": "#a292a3",
    "operator": "#c4746e",
    "parameter": "#a6a69c",
