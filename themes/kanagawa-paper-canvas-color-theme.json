{
  "$schema": "vscode://schemas/color-theme",
  "name": "Canvas",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "actionBar.toggledBackground": "#c1b4c1",
    "activityBar.activeBorder": "#7e8faf",
